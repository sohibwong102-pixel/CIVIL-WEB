---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, Disc, GitBranch, Shield, Zap } from 'lucide-react';

const workflowTimeline = [
  {
    step: "01",
    phase: "[PHASE_A_DISCOVERY]",
    title: "[LOREM_DISCOVERY_FLOW_TITLE]",
    desc: "[Lorem ipsum journey step discover hook. Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur.]",
    icon: Disc
  },
  {
    step: "02",
    phase: "[PHASE_B_INTEGRATION]",
    title: "[LOREM_INTEGRATION_FLOW_TITLE]",
    desc: "[Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis suscipit laboriosam, nisi ut aliquid ex ea commodi consequatur.]",
    icon: GitBranch
  },
  {
    step: "03",
    phase: "[PHASE_C_COMPLIANCE]",
    title: "[LOREM_SECURITY_COMPLIANCE_TITLE]",
    desc: "[At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores.]",
    icon: Shield
  },
  {
    step: "04",
    phase: "[PHASE_D_DEPLOYMENT]",
    title: "[LOREM_PRODUCTION_DEPLOY_TITLE]",
    desc: "[Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur, vel illum qui dolorem eum.]",
    icon: Zap
  }
];
---

<Layout title="Journey Pathway" description="Step-by-step structural workflow layout.">
  <div class="py-16 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto flex-grow">
    
    <!-- TIMELINE HEADER -->
    <div class="max-w-xl mx-auto text-center mb-16">
      <span class="text-[10px] font-mono tracking-widest text-slate-500 uppercase">[WORKFLOW_TIMELINE]</span>
      <h1 class="text-2xl sm:text-3xl font-sans font-semibold tracking-tight text-slate-900 dark:text-slate-50 mt-3 mb-4">
        [OPERATIONAL_JOURNEY_MAP_SCAFFOLD]
      </h1>
      <p class="text-slate-500 dark:text-slate-400 text-xs sm:text-sm leading-relaxed max-w-sm mx-auto">
        [Dummy description: Temporibus autem quibusdam et aut officiis debitis aut rerum necessitatibus saepe eveniet ut et voluptates.]
      </p>
    </div>

    {/* VERTICAL CONNECTING ROADMAP TIMELINE */}
    <div class="relative max-w-3xl mx-auto">
      {/* TIMELINE CONNECTOR BACKGROUND BAR */}
      <div class="absolute left-6 md:left-1/2 top-4 bottom-4 w-px bg-slate-200 dark:bg-slate-800 -translate-x-1/2 hidden md:block"></div>
      <div class="absolute left-6 top-4 bottom-4 w-px bg-slate-200 dark:bg-slate-800 md:hidden"></div>

      <div class="space-y-12">
        {workflowTimeline.map((item, index) => {
          const IconComponent = item.icon;
          const isEven = index % 2 === 0;
          
          return (
            <div class={`relative flex flex-col md:flex-row items-start ${isEven ? 'md:flex-row-reverse' : ''}`}>
              {/* HUB NODE ICON */}
              <div class="absolute left-6 md:left-1/2 w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 flex items-center justify-center -translate-x-1/2 z-10 transition-colors duration-200">
                <IconComponent class="w-5 h-5 text-slate-600 dark:text-slate-400" />
              </div>

              {/* EMPTY PLACEHOLDER SIDE FOR BALANCED DESKTOP GRID */}
              <div class="w-full md:w-1/2 hidden md:block"></div>

              {/* CARD DETAILS WRAPPER */}
              <div class="w-full md:w-1/2 pl-16 md:pl-0 md:px-8">
                <div class="p-6 rounded-xl border border-slate-200/60 dark:border-slate-800/60 bg-white/45 dark:bg-slate-950/25 backdrop-blur-sm transition-all duration-200 hover:-translate-y-0.5">
                  <div class="flex items-center justify-between gap-4 mb-2">
                    <span class="font-mono text-[9px] text-slate-400 dark:text-slate-500 tracking-wider">
                      {item.phase}
                    </span>
                    <span class="font-mono text-xs font-semibold text-slate-300 dark:text-slate-700 select-none">
                      #{item.step}
                    </span>
                  </div>
                  
                  <h3 class="text-sm font-sans font-medium text-slate-900 dark:text-slate-100 mb-2">
                    {item.title}
                  </h3>
                  
                  <p class="text-[11px] font-mono leading-relaxed text-slate-500 dark:text-slate-400">
                    {item.desc}
                  </p>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    </div>

    <!-- CALL-TO-ACTION FOR JOURNEY TERMINAL -->
    <div class="mt-20 text-center">
      <div class="inline-flex items-center gap-1.5 font-mono text-xs">
        <span class="text-slate-400">[READY_TO_START_JOURNEY]?</span>
        <a href="/try-now" class="text-slate-900 dark:text-slate-100 font-semibold hover:underline flex items-center gap-1 cursor-pointer">
          <span>[PROCEED_TO_SANDBOX]</span>
          <ArrowRight class="w-3 h-3" />
        </a>
      </div>
    </div>

  </div>
</Layout>
