---
// Static Hero section preserving responsive design and modern minimal aesthetic
---

<section class="relative py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-50 to-slate-100/30 dark:from-slate-950 dark:to-slate-950 transition-colors duration-200">
  <!-- LIGHT STRETCHED DOT BACKGROUND FOR OPERATIONAL AESTHETIC -->
  <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] dark:bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-60 pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto text-center z-10">
    <!-- SUB-HEADER LEVEL TAG -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-slate-200 dark:border-slate-800 bg-slate-100/55 dark:bg-slate-900 text-[11px] xl:text-[14px] font-mono tracking-wider text-slate-600 dark:text-slate-400 mb-6 uppercase">
      <span class="w-1.5 h-1.5 rounded-full bg-slate-400 dark:bg-slate-600 animate-pulse"></span>
      <span>API CIVIL GROUP</span>
    </div>

    <!-- MAIN TYPOGRAPHY HEADER -->
    <!-- HERO SECTION -->
    <!-- Replace with landing page headline -->
    <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-sans font-semibold tracking-tight text-slate-900 dark:text-slate-50 max-w-4xl mx-auto leading-[1.1] mb-6">
      LumaSite API
    </h1>

    <!-- BODY DESCRIPTION -->
    <p class="text-slate-500 dark:text-slate-400 text-sm sm:text-base max-w-2xl mx-auto leading-relaxed mb-10">
      Build systems for humans, not just for technology<br>
      Teknologi seharusnya membantu manusia<br>
      bekerja lebih nyaman -
      bukan membuat mereka semakin lelah.
    </p>

    <!-- ACTION ACTION AREA -->
    <!-- PRIMARY CTA -->
    <!-- Replace with final action button -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-16">
      <a 
        href="/try-now" 
        class="w-full sm:w-auto px-6 py-2.5 text-xs font-mono tracking-wide bg-slate-900 dark:bg-slate-100 text-slate-50 dark:text-slate-950 hover:bg-slate-800 dark:hover:bg-slate-800 hover:text-slate-200 rounded-lg shadow-md font-medium transition-all"
      >
        Coba Sekarang
      </a>
      <a 
        href="/journey" 
        class="w-full sm:w-auto px-6 py-2.5 text-xs font-mono tracking-wide border border-slate-205 dark:border-slate-800 bg-slate-100/30 hover:bg-slate-100 dark:hover:bg-slate-900 hover:text-slate-100 text-slate-700 dark:text-slate-200 rounded-lg transition-all"
      >
        Dokumentasi
      </a>
    </div>

    <!-- MOCK INTERACTIVE INTERFACE WORKBENCH WIREFRAME (operational layout placeholder) -->
    <div class="border border-slate-200/80 dark:border-slate-800/80 bg-slate-50/50 dark:bg-slate-950/40 rounded-xl overflow-hidden shadow-md max-w-4xl mx-auto">
      {/* HEADER BAR */}
      <div class="h-10 bg-slate-100/80 dark:bg-slate-900/60 border-b border-slate-200/80 dark:border-slate-800/80 px-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-red-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-green-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-blue-500"></span>
          </div>
          <span class="text-[11px] font-mono text-slate-400 dark:text-slate-500 ml-2 select-none">/lumasitehq/api/issue</span>
        </div>
        <div class="text-[11px] font-mono text-slate-400 dark:text-slate-300 bg-slate-200/50 dark:bg-slate-800/50 px-2 py-0.5 rounded">
         Mode
        </div>
      </div>

      {/* INNER OPERATIONAL VIEW */}
      <div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-4 font-mono text-left">
        <div class="md:col-span-2 border border-slate-200/60 dark:border-slate-800/60 rounded-lg p-4 bg-slate-50/20 dark:bg-slate-950/20">
          <div class="text-[10px] text-slate-400 dark:text-slate-500 mb-2">// query user input</div>
          <p class="text-[11px] text-slate-600 dark:text-slate-400 leading-relaxed max-w-lg">
            "Saya sangat mencintai backend dan frontend, saya ingin terus berkembang didalamnya."
          </p>
        </div>
        <div class="border border-slate-200/60 dark:border-slate-800/60 rounded-lg p-4 bg-slate-50/20 dark:bg-slate-950/20 flex flex-col justify-between">
          <div>
            <div class="text-[10px] text-slate-400 dark:text-slate-500 mb-2">// WORKFLOW_STATUS</div>
            <div class="h-1.5 w-full bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden mb-1">
              <div class="h-full w-[65%] bg-slate-600 dark:bg-slate-400 rounded-full"></div>
            </div>
          </div>
          <div class="text-[10px] text-slate-600 dark:text-slate-400">
            Ping: 14ms<br />
            RESOURCES: 98.4%
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
