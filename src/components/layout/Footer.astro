---
// 🔚 FOOTER COMPONENT - links ke berbagai section + copyright
const currentYear = new Date().getFullYear();
---

<footer class={[
      // SURFACE
      'border-t border-slate-200/50 dark:border-slate-800/50 bg-slate-50/60 dark:bg-slate-950/40 text-slate-500 dark:text-slate-500',
      // SPACING
      'py-12',
      // TYPOGRAPHY
      'font-mono text-[11px]',
      // TRANSITION
      'transition-colors duration-200'
    ].join(' ')}>
  <div class={[
      // LAYOUT
      'max-w-7xl mx-auto',
      // SPACING
      'px-4 sm:px-6 lg:px-8'
    ].join(' ')}>
    <!-- 📊 FOOTER GRID: 4 columns, 2 columns di mobile -->
    <div class={[
      // LAYOUT
      'grid grid-cols-2 md:grid-cols-4',
      // SPACING
      'gap-8 pb-12'
    ].join(' ')}>
      <!-- Column 1: Produk/struktur yang ditawarkan -->
      <div>
        <h3 class="text-slate-800 dark:text-slate-400 font-medium mb-3 tracking-wider">WORKFLOW</h3>
        <ul class="space-y-2">
          <li><a href="/products" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Workflow Templates</a></li>
          <li><a href="/products" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Starter Structure</a></li>
          <li><a href="/products" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Modular Setup</a></li>
        </ul>
      </div>

      <!-- Column 2: Dokumentasi -->
      <div>
        <h3 class="text-slate-800 dark:text-slate-400 font-medium mb-3 tracking-wider">INFORMASI</h3>
        <ul class="space-y-2">
          <li><a href="/docs" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Mulai belajar</a></li>
          <li><a href="/docs" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Panduan</a></li>
          <li><a href="/docs" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Dokumentasi</a></li>
        </ul>
      </div>

      <!-- Column 3: Utility links seperti pricing, journey, FAQ -->
      <div>
        <h3 class="text-slate-800 dark:text-slate-400 font-medium mb-3 tracking-wider">SYSTEM</h3>
        <ul class="space-y-2">
          <li><a href="/pricing" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Estimasi Harga</a></li>
          <li><a href="/journey" class="hover:text-slate-800 dark:hover:text-slate-200">◇ Perjalanan CIVIL</a></li>
          <li><a href="/faq" class="hover:text-slate-800 dark:hover:text-slate-200">◇ FAQ</a></li>
        </ul>
      </div>

      <!-- Column 4: Legal links -->
      <div>
        <h3 class="text-slate-800 dark:text-slate-400 font-medium mb-3 tracking-wider">LEGALITAS</h3>
        <ul class="space-y-2">
          <li><span class="block text-slate-400 dark:text-slate-600">◇ Privacy</span></li>
          <li><span class="block text-slate-400 dark:text-slate-600">◇ Terms</span></li>
          <li><span class="block text-slate-400 dark:text-slate-600">◇ FeedBack</span></li>
        </ul>
        
      </div>
    </div>
    <p class="text-center mb-2 mx-auto text-slate-400 dark:text-slate-600 text-[11px] max-w-sm leading-relaxed">
        Workflow seharusnya membantu kerja terasa lebih ringan
      </p>
    <!-- 📜 FOOTER BOTTOM: copyright + template info -->
    <div class={[
      // SURFACE
      'border-t border-slate-200/40 dark:border-slate-800/40',
      // SPACING
      'pt-6 gap-4',
      // LAYOUT
      'flex flex-col sm:flex-row items-center justify-between'
    ].join(' ')}>
    
      <div class={[
        // LAYOUT
        'flex items-center gap-2',
        // TYPOGRAPHY
        'text-slate-400 dark:text-slate-600'
      ].join(' ')}>
      
        <span>Dibangun untuk manusia yang capek sama platform chaos</span>
      </div>
      <div class="text-slate-400 dark:text-slate-600">
        <span>© {currentYear} CIVIL GROUP - Built with Clarity & Comfort</span>
      </div>
    </div>
  </div>
</footer>
