---
// 🎨 MAIN LAYOUT TEMPLATE - setiap page di-wrap dengan layout ini
import Navbar from '../components/navigation/Navbar.tsx';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

// Props: title = judul halaman, description = meta description buat SEO
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A simple, clean modular multi-page landing page scaffold" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌐</text></svg>" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | CIVIL-Web</title>
    <meta name="description" content={description} />
    
    <!-- ⚡ DARK MODE: setup tema sebelum page render (avoid flash) -->
    <!-- Logika: ambil dari localStorage, kalau nggak ada pakai system preference -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const theme = getThemePreference();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      // Sync localStorage ketika user ubah theme via button
      if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>
  </head>
  <body class={[
      // SURFACE
      'bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100',
      // LAYOUT
      'flex flex-col min-h-screen',
      // TYPOGRAPHY
      'antialiased',
      // TRANSITION
      'transition-colors duration-200'
    ].join(' ')}>
    <!-- 🧭 NAVBAR: fixed di atas, ada logo + menu links + theme toggle -->
    <Navbar client:load />

    <!-- 📄 PAGE CONTENT: section utama yang berisi konten per halaman -->
    <main class="flex-grow flex flex-col pt-16">
      <slot />
    </main>

    <!-- 🔚 FOOTER: di bawah semua page, biasanya copyright + links -->
    <Footer />
  </body>
</html>
